{
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(dart analyze:*)",
      "Bash(dart run build_runner:*)",
      "Bash(flutter pub get:*)",
      "Bash(alembic:*)",
      "Bash(pytest:*)"
    ]
  },
  "hooks": {
    "Stop": [
