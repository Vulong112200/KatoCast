# KatoAssistant backend — sao chép thành .env và điền giá trị thật (KHÔNG commit .env)

# PostgreSQL (async). Dùng SQLite cho dev nhanh: sqlite+aiosqlite:///./katoassistant.db
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/katoassistant

# Claude API — để trống thì verify_service dùng rule-based fallback
ANTHROPIC_API_KEY=

# Model dùng cho phân loại/tóm tắt (rẻ)
VERIFY_MODEL=claude-haiku-4-5-20251001

# CORS cho app mobile (dev). Prod nên siết lại.
CORS_ORIGINS=*

# User-Agent khi crawl nguồn ngoài
CRAWL_USER_AGENT=KatoAssistant/1.0 (+https://github.com/VuhpAlx)
